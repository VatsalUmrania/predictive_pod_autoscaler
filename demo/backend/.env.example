# ShopDemo — Environment Variables
# Copy this to .env and fill in values

# NEXUS Integration
NEXUS_API_URL=http://localhost:8080
SELFHEAL_TOKEN=               # Auto-generated on first startup if left blank

# Database
DEMO_DB_PATH=shop.db

# App
APP_PORT=8001
APP_NAME=shop-demo

# Optional: Gemini API key for LLM-powered RCA in demo orchestrator
NEXUS_GEMINI_API_KEY=

# Optional: Slack notifications
SLACK_WEBHOOK=
