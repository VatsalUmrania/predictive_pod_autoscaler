# Dataflow Dockerfile — rendered by render_dataflow_dockerfile() in startup.py.
# Variables are substituted at startup time using Jinja2.
# Build context should be PROJECT_DIR (root of the repo).
# Usage:
#   jinja2 -D image_tag={{ image_tag }} -D pip_packages="{{ pip_packages }}" ...
#   Or via startup.py which calls render_dataflow_dockerfile().

FROM {{ base_image | default("python:3.11-slim") }}

WORKDIR /app

COPY src/ppa/common/ src/ppa/common/
COPY src/ppa/dataflow/ src/ppa/dataflow/

{% if pip_packages %}
RUN pip install --no-cache-dir {{ pip_packages }}
{% else %}
RUN pip install --no-cache-dir \
    pandas>=2.0.0 \
    numpy>=1.26.0 \
    requests>=2.31.0 \
    prometheus-client>=0.19.0 \
    joblib>=1.4.0 \
    scikit-learn>=1.5.0
{% endif %}

CMD {{ cmd if cmd else '["python3", "-m", "ppa.dataflow.export_training_data"]' }}
